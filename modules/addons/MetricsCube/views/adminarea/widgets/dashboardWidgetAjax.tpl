<link href="{$SCRIPT_NAME}/../../modules/addons/MetricsCube/assets/css/user-widget.css" rel="stylesheet"
      type="text/css"/>
<div class="user-widget user-widget--static popover popover--customer-static popover--dashboard"
     data-user-widget-summary>
    <div class="user-popover user-popover--banner user-popover--no-shadow user-popover--static">
        <div class="user-popover__logo">
