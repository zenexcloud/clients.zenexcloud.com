                                  stroke-linejoin="round"/>
                            <path d="M7.5 9.00003L15 1.50003" stroke="#0091EA" stroke-linecap="round"
                                  stroke-linejoin="round"/>
                        </svg>
                    </div>
                </a>
            </div>
        {/if}
    </div>
</div>
<script>
	window.MCPermissions = {$MetricsCubePermissions|json_encode}
	window.MCSettings = {$MetricsCubeSettings|json_encode}
</script>
