                                <path d="M58.95 33H46.6" stroke="#444444" stroke-width="1.3" stroke-linecap="round"/>
                                <g opacity="0.48">
                                    <path fill-rule="evenodd" clip-rule="evenodd"
                                          d="M9.25001 63.75C9.4224 63.75 9.58773 63.8501 9.70963 64.0282C9.83152 64.2064 9.90001 64.448 9.90001 64.7V66.6C9.90001 66.852 9.83152 67.0936 9.70963 67.2718C9.58773 67.4499 9.4224 67.55 9.25001 67.55C9.07762 67.55 8.91229 67.4499 8.79039 67.2718C8.66849 67.0936 8.60001 66.852 8.60001 66.6V64.7C8.60001 64.448 8.66849 64.2064 8.79039 64.0282C8.91229 63.8501 9.07762 63.75 9.25001 63.75Z"
