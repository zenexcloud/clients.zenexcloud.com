                                          fill="#444444"/>
                                </g>
                                <path d="M20 40C30.4934 40 39 31.4934 39 21C39 10.5066 30.4934 2 20 2C9.50659 2 1 10.5066 1 21C1 31.4934 9.50659 40 20 40Z"
                                      fill="white" stroke="#444444" stroke-width="1.3" stroke-linecap="round"/>
                                <path d="M26.0458 14.9542L13.9542 27.0458" stroke="#444444" stroke-width="1.3"
                                      stroke-linecap="round"/>
                                <path d="M13.9542 14.9542L26.0458 27.0458" stroke="#444444" stroke-width="1.3"
                                      stroke-linecap="round"/>
                                <path opacity="0.15" fill-rule="evenodd" clip-rule="evenodd"
                                      d="M19.5385 40C19.0185 40 18.5128 39.9631 18 39.9198C22.6116 39.5247 26.9105 37.3602 30.044 33.8557C33.1776 30.3511 34.9168 25.7625 34.9168 21C34.9168 16.2375 33.1776 11.6489 30.044 8.14433C26.9105 4.63979 22.6116 2.47532 18 2.08022C18.5128 2.03589 19.0185 2 19.5385 2C24.4348 2 29.1305 4.00178 32.5927 7.56497C36.055 11.1282 38.5 15.9609 38.5 21C38.5 26.0391 36.055 30.8718 32.5927 34.435C29.1305 37.9982 24.4348 40 19.5385 40Z"
                                      fill="#444444"/>
                            </svg>
                        </div>
                        <p class="p1 zero-data__title">Data not available</p>
                    </div>
                </div>
            {elseif (isset($requestStatus) && $requestStatus == false) || $info.errorType == "synchronizationInProgress"}
                 <div class="zero-data zero-data--empty">
                    <span class="zero-data__title">
                    	{if $info.errorType &&  ($info.errorType == "appKeyEmpty" || $info.errorType == "invalidKey")}
                            Displaying recent activity requires you </br> to connect with MetricsCube.
                            <a data-registrationmodal data-auto-open>
                                Try MetricsCube For Free
                            </a>
                        {else}
                            Recent activity data will appear here soon.
                        {/if}
                    </span>
                </div>
            {else}
                <div class="popover__loader" data-popover-loader>
                    <div class="loader"></div>
                </div>
            {/if}
        </div>
        {if isset($activity) && $activity && $activity|count}
            <div class="user-popover__footer">
                <a href="{if isset($url) && isset($url['activity'])}{$url['activity']}{/if}" target="_blank"
                   class="user-popover__footer-container flex-center">
                    <span class="text">See the list of all events at MetricsCube</span>
                    <div class="icon-container">
                        <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13.0274 8.22773L13.0273 12.1667C13.0273 12.5203 12.8868 12.8595 12.6368 13.1095C12.3867 13.3596 12.0476 13.5 11.694 13.5H4.33333C3.97971 13.5 3.64057 13.3596 3.39052 13.1095C3.14048 12.8595 3 12.5203 3 12.1667L3.00011 4.83336C3.00011 4.47974 3.14058 4.1406 3.39063 3.89055C3.64068 3.64051 3.97982 3.50003 4.33344 3.50003H8.36073"
