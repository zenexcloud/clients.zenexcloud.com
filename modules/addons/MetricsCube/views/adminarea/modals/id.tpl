<div class="lu-modal" id="application-id-modal">
    <div class="lu-modal__dialog">
        <div class="lu-modal__content">
            <div class="lu-modal__top lu-top">
                <h2 class="lu-top__title lu-h4">Application ID</h2>
                <div class="lu-top__toolbar">
                    <button class="lu-close lu-btn lu-btn--sm lu-btn--icon lu-btn--link" data-dismiss="lu-modal"
                            aria-label="Close">
                        <i class="lu-btn__icon lu-zmdi lu-zmdi-close"></i>
                    </button>
                </div>
            </div>
            <div class="lu-modal__body">
                <p>
                    You will find your Application Key in the MetricsCube Wizard right after registering your account or
                    when trying to connect another application.
                    If you have not created your account yet, feel free to register for 14-day trial at <a
                            href="https://dashboard.metricscube.io/sign-up" target="__blank">https://dashboard.metricscube.io/sign-up</a>
                </p>
            </div>
            <div class="lu-modal__actions">
                <button class="lu-btn lu-btn--default lu-btn--outline" type="button" data-dismiss="lu-modal"
                        aria-label="Close">
                    <span class="lu-btn__text">Hide</span>
                </button>
            </div>
        </div>
    </div>
</div>